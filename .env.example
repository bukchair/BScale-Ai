# === Core app configuration ===
# Production:
#   APP_URL="https://bscale.co.il"
# Local development:
#   APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === Meta (Facebook / Instagram Ads) ===
# Create an app in https://developers.facebook.com/
# and copy the App ID + App Secret.
META_APP_ID=""
META_APP_SECRET=""
# For production use your live domain; for local use http://localhost:3000
META_REDIRECT_URI="https://bscale.co.il/api/auth/meta/callback"

# === Google (Ads, GA4, GSC, Gmail, OAuth) ===
# OAuth 2.0 Client ID for Web in Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://bscale.co.il/api/auth/google/callback"

# === TikTok Ads ===
# Create app in https://business-api.tiktok.com/
TIKTOK_APP_ID=""
TIKTOK_SECRET=""
TIKTOK_REDIRECT_URI="https://bscale.co.il/api/auth/tiktok/callback"
